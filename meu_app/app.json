{
  "expo": {
    "name": "StashFlix",
    "slug": "stashflix7",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.jpg",
    "scheme": "ksafevault",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ksafe.vault",
      "buildNumber": "1.0.0"
    },
    "android": {
      "package": "com.ksafe.vault",
      "versionCode": 1,
      "permissions": [
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#050000",
        "foregroundImage": "./assets/images/app-icon.jpg"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/app-icon.jpg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/logo-dark.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-media-library",
        {
          "photosPermission": "Permita que o StashFlix acesse suas fotos para salva-las no cofre.",
          "savePhotosPermission": "Permita que o StashFlix salve as mídias.",
          "isAccessMediaLocationEnabled": true,
          "granularPermissions": [
            "audio",
            "photo",
            "video"
          ]
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permita o acesso à câmera para fotografar intrusos.",
          "microphonePermission": "Permita o acesso ao microfone para gravar o áudio do ambiente em caso de invasão."
        }
      ],
      "expo-build-properties",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "934b512e-b1b4-4fab-9a51-ef2aa811bf1c"
      }
    },
    "owner": "maykecorrea7s-organization"
  }
}
